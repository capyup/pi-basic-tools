{
  "name": "pi-basic-tools",
  "version": "0.1.0",
  "description": "Standalone core productivity tools for pi: question, todo, files, webfetch, answer, Sourcegraph, and OpenCode-style search.",
  "repository": {
    "type": "git",
    "url": "https://github.com/lulucatdev/pi-basic-tools.git"
  },
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "editing",
    "search"
  ],
  "scripts": {
    "test": "node --test tests/*.test.mjs"
  },
  "pi": {
    "extensions": [
      "./extensions/files.ts",
      "./extensions/webfetch.ts",
      "./extensions/search.ts",
      "./extensions/basic-tools.ts",
      "./extensions/answer.ts",
      "./extensions/sourcegraph.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@sinclair/typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "@sinclair/typebox": {
      "optional": true
    }
  },
  "dependencies": {
    "turndown": "^7.2.4"
  }
}
